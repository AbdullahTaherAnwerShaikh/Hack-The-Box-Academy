=========================================
BACKUP & RESTORE CHEAT SHEET
=========================================

-------------------------------------------------
1. TAR (Archive Files)
-------------------------------------------------

# Create archive
tar -cf backup.tar file1 file2 dir/

# Archive entire directory
tar -cf backup.tar /home/user/

# List archive contents
tar -tf backup.tar

# Extract archive
tar -xf backup.tar

# Extract to directory
tar -xf backup.tar -C /tmp/

# Extract specific file
tar -xf backup.tar file.txt

-------------------------------------------------
2. COMPRESSED TAR ARCHIVES
-------------------------------------------------

# gzip (.tar.gz / .tgz)
tar -czf backup.tar.gz dir/
tar -xzf backup.tar.gz

# bzip2 (.tar.bz2)
tar -cjf backup.tar.bz2 dir/
tar -xjf backup.tar.bz2

# xz (.tar.xz)
tar -cJf backup.tar.xz dir/
tar -xJf backup.tar.xz

-------------------------------------------------
3. GZIP / BZIP2 / XZ
-------------------------------------------------

# Compress
gzip file
bzip2 file
xz file

# Decompress
gunzip file.gz
bunzip2 file.bz2
unxz file.xz

# Keep original
gzip -k file
bzip2 -k file
xz -k file

-------------------------------------------------
4. ZIP
-------------------------------------------------

# Create zip
zip backup.zip file
zip -r backup.zip directory/

# List contents
unzip -l backup.zip

# Extract
unzip backup.zip

-------------------------------------------------
5. RSYNC
-------------------------------------------------

# Local backup
rsync -av source/ destination/

# Preserve permissions, ownership, timestamps
rsync -a source/ destination/

# Show progress
rsync -av --progress source/ destination/

# Delete removed files
rsync -av --delete source/ destination/

# Dry run
rsync -av --dry-run source/ destination/

# Remote backup
rsync -av user@host:/dir .

# Upload
rsync -av folder/ user@host:/backup/

-------------------------------------------------
6. SCP
-------------------------------------------------

# Download
scp user@host:/file .

# Upload
scp file user@host:/dir/

# Recursive
scp -r folder user@host:/dir/

-------------------------------------------------
7. DD (Disk Imaging)
-------------------------------------------------

# Clone disk
sudo dd if=/dev/sda of=/dev/sdb bs=4M status=progress

# Create image
sudo dd if=/dev/sda of=disk.img bs=4M status=progress

# Restore image
sudo dd if=disk.img of=/dev/sda bs=4M status=progress

