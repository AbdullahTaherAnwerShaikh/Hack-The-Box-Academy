=========================================
NETWORK SERVICES + WEB SERVICES CHEAT SHEET
=========================================

-------------------------------------------------
1. HOST DISCOVERY & DNS
-------------------------------------------------

hostname
hostname -I
ip a
ip route
ping <host>

nslookup <domain>
dig <domain>
dig @<DNS_Server> <domain>
host <domain>

-------------------------------------------------
2. PORT ENUMERATION
-------------------------------------------------

# Check listening ports
ss -tulnp
ss -tun
netstat -tulnp

# Which process owns a port?
lsof -i :80
fuser 80/tcp

-------------------------------------------------
3. HTTP / HTTPS (curl)
-------------------------------------------------

# View webpage
curl http://IP

# View only headers
curl -I http://IP

# Verbose request
curl -v http://IP

# Follow redirects
curl -L http://IP

# Ignore SSL certificate
curl -k https://IP

# Download file
curl -O http://IP/file
curl -o output.txt http://IP/file

# Basic Authentication
curl -u user:password http://IP

# POST request
curl -X POST http://IP/login \
-d "username=admin&password=admin"

# Send JSON
curl -X POST http://IP/api \
-H "Content-Type: application/json" \
-d '{"user":"admin"}'

# Custom Header
curl -H "User-Agent: Mozilla/5.0" http://IP

# Cookies
curl -c cookies.txt http://IP
curl -b cookies.txt http://IP

-------------------------------------------------
4. HTTP / HTTPS (wget)
-------------------------------------------------

wget http://IP/file
wget -O filename http://IP/file
wget -c http://IP/file
wget -r http://IP

