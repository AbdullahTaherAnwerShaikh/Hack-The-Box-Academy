=========================================
NETWORK CONFIGURATION CHEAT SHEET
=========================================

-------------------------------------------------
1. VIEW NETWORK INTERFACES
-------------------------------------------------

# Show all interfaces
ip a
ip addr
ip addr show

# Show only active interfaces
ip link

# Legacy
ifconfig

-------------------------------------------------
2. ENABLE / DISABLE INTERFACE
-------------------------------------------------

# Bring interface up
sudo ip link set eth0 up

# Bring interface down
sudo ip link set eth0 down

# Legacy
ifup eth0
ifdown eth0

-------------------------------------------------
3. ASSIGN IP ADDRESSES
-------------------------------------------------

# Add static IP
sudo ip addr add 192.168.1.100/24 dev eth0

# Delete IP
sudo ip addr del 192.168.1.100/24 dev eth0

# Flush all IPs
sudo ip addr flush dev eth0

-------------------------------------------------
4. DHCP
-------------------------------------------------

# Request IP
sudo dhclient eth0

# Release IP
sudo dhclient -r eth0

# Renew lease
sudo dhclient eth0

-------------------------------------------------
5. ROUTING
-------------------------------------------------

# View routing table
ip route
route -n

# Add default gateway
sudo ip route add default via 192.168.1.1

# Delete default gateway
sudo ip route del default

# Add static route
sudo ip route add 10.10.10.0/24 via 192.168.1.1

-------------------------------------------------
6. DNS
-------------------------------------------------

# DNS configuration
cat /etc/resolv.conf

# Typical entries
nameserver 8.8.8.8
nameserver 1.1.1.1
search company.local

-------------------------------------------------
7. NETWORK CONFIGURATION FILES
-------------------------------------------------

# Legacy Debian/Ubuntu
/etc/network/interfaces

# DNS
/etc/resolv.conf

# Hostname
/etc/hostname

# Local hostname mappings
/etc/hosts

# Ubuntu (Netplan)
/etc/netplan/*.yaml

# NetworkManager
/etc/NetworkManager/

-------------------------------------------------
8. HOSTNAME
-------------------------------------------------

hostname
hostnamectl

# Change hostname
sudo hostnamectl set-hostname newhost

-------------------------------------------------
9. /etc/hosts
-------------------------------------------------

# View
cat /etc/hosts

# Example
127.0.0.1 localhost
192.168.1.10 server

-------------------------------------------------
10. DNS TOOLS
-------------------------------------------------

nslookup google.com
dig google.com
dig @8.8.8.8 google.com
host google.com

-------------------------------------------------
11. CONNECTIVITY TESTING
-------------------------------------------------

ping 8.8.8.8
ping google.com

traceroute google.com
tracepath google.com

-------------------------------------------------
12. ARP / NEIGHBOR TABLE
-------------------------------------------------

